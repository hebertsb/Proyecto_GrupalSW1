{
  "name": "smart-condominium",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:all": "turbo run dev --parallel",
    "dev:web": "npm run dev -w @si2/web",
    "dev:backend": "npm run dev -w @si2/backend",
    "dev:mobile": "npm run dev -w @si2/mobile",
    "build": "npm run build --workspace=@si2/web",
    "build:force": "npm install --force && npm run build --workspace=@si2/web",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "turbo": "^1.10.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "react-router-dom": "^7.8.2",
    "tailwindcss": "^4.1.13",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": "20.x"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@^4.21.0"
  },
  "packageManager": "npm@10.9.2"
}
